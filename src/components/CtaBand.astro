---
interface Props {
  heading?: string;
  sub?: string;
}
const {
  heading = 'Let’s take the books off your plate.',
  sub = 'Tell us about your business and we’ll put together a proposal that fits — no obligation.',
} = Astro.props;
---
<section class="bg-navy-deep">
  <div class="container-v py-20 text-center">
    <h2 class="mx-auto max-w-2xl text-3xl font-bold leading-tight text-white sm:text-4xl">{heading}</h2>
    <p class="mx-auto mt-4 max-w-xl text-white/55">{sub}</p>
    <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
      <a href="/contact#quote" class="btn-primary">Request a quote</a>
      <a href="/contact" class="btn-ghost">Contact us</a>
    </div>
  </div>
</section>
