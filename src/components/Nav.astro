---
const links = [
  { href: '/', label: 'Home' },
  { href: '/services', label: 'Services' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];
// Client portal login (Virta platform). Update if the firm uses a different login.
const loginUrl = 'https://newportal.virta.co.za/login';
---

<header class="sticky top-0 z-50 border-b border-white/10 bg-navy-deep/90 backdrop-blur">
  <nav class="container-v flex h-16 items-center justify-between">
    <a href="/" class="flex items-baseline gap-0.5 text-lg font-bold tracking-tight">
      <span class="text-white">MyFINANCE</span><span class="text-accent">Online</span>
    </a>

    <div class="hidden items-center gap-7 md:flex">
      {links.map((l) => (
        <a href={l.href} class="text-sm font-medium text-white/70 transition-colors hover:text-white">{l.label}</a>
      ))}
    </div>

    <div class="flex items-center gap-3">
      <a href={loginUrl} class="hidden text-sm font-medium text-white/70 transition-colors hover:text-white sm:inline">Client login</a>
      <a href="/contact" class="btn-primary !px-5 !py-2.5">Get in touch</a>
    </div>
  </nav>
</header>
