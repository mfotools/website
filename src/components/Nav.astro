---
const links = [
  { href: '/', label: 'Home' },
  { href: '/services', label: 'Services' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];
// Client portal login (Virta platform). Update if the firm uses a different login.
const loginUrl = 'https://newportal.virta.co.za/login';
---

<header class="sticky top-0 z-50 border-b border-slate-200 bg-white/95 backdrop-blur">
  <nav class="container-v flex h-[4.5rem] items-center justify-between">
    <a href="/" class="flex items-center">
      <img src="/logo.png" alt="MyFINANCE Online — accountants & business advisors" class="h-10 w-auto" />
    </a>

    <div class="hidden items-center gap-8 md:flex">
      {links.map((l) => (
        <a href={l.href} class="text-sm font-medium text-navy/70 transition-colors hover:text-navy">{l.label}</a>
      ))}
    </div>

    <div class="flex items-center gap-3">
      <a href={loginUrl} class="hidden text-sm font-medium text-navy/70 transition-colors hover:text-navy sm:inline">Client login</a>
      <a href="/contact" class="btn-primary !px-5 !py-2.5">Get in touch</a>
    </div>
  </nav>
</header>
