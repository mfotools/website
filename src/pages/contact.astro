---
import Base from '../layouts/Base.astro';

// ── Web3Forms setup ───────────────────────────────────────────────────────
// 1. Create a free account at https://web3forms.com (no login needed — it just
//    asks for the email submissions should go to) and copy your Access Key.
// 2. Paste it below. The SAME key is used by all three forms; submissions are
//    labelled by the "subject" field so you can tell them apart in your inbox.
// 3. That's it — the forms POST straight to Web3Forms, which emails you. No
//    backend, no server config. Works on any static host.
const WEB3FORMS_ACCESS_KEY = 'PASTE-YOUR-WEB3FORMS-ACCESS-KEY-HERE';

// Where the browser lands after a successful submit (the thank-you page).
const REDIRECT_URL = 'https://www.myfinance-online.co.za/thank-you';

// TODO: confirm the firm's real phone number and office hours.
const email = 'tax@myfinance-online.co.za';
const phone = '+27 (0)51 000 0000';
---
<Base title="Contact — MyFINANCE Online" description="Get in touch with MyFINANCE Online — request a quote, book a callback or send us a message. Bloemfontein-based accounting, tax and payroll.">
  <!-- Header -->
  <section class="bg-navy-deep">
    <div class="container-v py-20">
      <span class="eyebrow">Contact us</span>
      <h1 class="mt-4 max-w-3xl text-4xl font-bold leading-tight tracking-tight text-white sm:text-5xl">
        Let’s start a conversation.
      </h1>
      <p class="mt-5 max-w-2xl text-lg leading-relaxed text-white/60">
        Send a message, ask for a quote, or book a callback — whichever suits you. We usually reply within one business day.
      </p>
    </div>
  </section>

  <section class="container-v py-20">
    <div class="grid gap-12 lg:grid-cols-[0.8fr_1.2fr] lg:items-start">
      <!-- Contact details -->
      <div class="space-y-8">
        <div>
          <h2 class="text-sm font-semibold uppercase tracking-wider text-slate-400">Reach us directly</h2>
          <ul class="mt-4 space-y-4 text-sm">
            <li>
              <div class="font-medium text-navy">Email</div>
              <a href={`mailto:${email}`} class="text-accent hover:underline">{email}</a>
            </li>
            <li>
              <div class="font-medium text-navy">Phone</div>
              <a href={`tel:${phone.replace(/[^+0-9]/g, '')}`} class="text-slate-600 hover:text-navy">{phone}</a>
            </li>
            <li>
              <div class="font-medium text-navy">Office</div>
              <span class="text-slate-600">100 Waverley Road,<br />Bloemfontein, Free State, South Africa</span>
            </li>
            <li>
              <div class="font-medium text-navy">Hours</div>
              <span class="text-slate-600">Mon–Fri, 08:00–17:00</span>
            </li>
          </ul>
        </div>
        <div class="rounded-2xl border border-slate-200 bg-slate-50 p-6">
          <h3 class="text-base font-semibold text-navy">Already a client?</h3>
          <p class="mt-2 text-sm leading-relaxed text-slate-600">Log in to your secure portal to share documents and view your work.</p>
          <a href="https://newportal.virta.co.za/login" class="btn-dark mt-4 !px-5 !py-2.5">Client login</a>
        </div>
      </div>

      <!-- Forms -->
      <div class="space-y-12">
        <!-- General enquiry -->
        <div class="rounded-2xl border border-slate-200 bg-white p-7 shadow-sm">
          <h2 class="text-xl font-bold text-navy">Send us a message</h2>
          <p class="mt-1.5 text-sm text-slate-500">General enquiries — we’ll get back to you shortly.</p>
          <form action="https://api.web3forms.com/submit" method="POST" class="mt-6 grid gap-4 sm:grid-cols-2">
            <input type="hidden" name="access_key" value={WEB3FORMS_ACCESS_KEY} />
            <input type="hidden" name="subject" value="Website enquiry — General message" />
            <input type="hidden" name="from_name" value="MyFINANCE Online website" />
            <input type="hidden" name="redirect" value={REDIRECT_URL} />
            <input type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" autocomplete="off" />

            <div>
              <label class="label" for="g-name">Name</label>
              <input class="field" id="g-name" type="text" name="name" required placeholder="Your name" />
            </div>
            <div>
              <label class="label" for="g-email">Email</label>
              <input class="field" id="g-email" type="email" name="email" required placeholder="you@example.com" />
            </div>
            <div class="sm:col-span-2">
              <label class="label" for="g-phone">Phone (optional)</label>
              <input class="field" id="g-phone" type="tel" name="phone" placeholder="082 000 0000" />
            </div>
            <div class="sm:col-span-2">
              <label class="label" for="g-message">Message</label>
              <textarea class="field" id="g-message" name="message" rows="4" required placeholder="How can we help?"></textarea>
            </div>
            <div class="sm:col-span-2">
              <button type="submit" class="btn-primary w-full sm:w-auto">Send message</button>
            </div>
          </form>
        </div>

        <!-- Request a quote -->
        <div id="quote" class="scroll-mt-24 rounded-2xl border border-slate-200 bg-white p-7 shadow-sm">
          <h2 class="text-xl font-bold text-navy">Request a quote</h2>
          <p class="mt-1.5 text-sm text-slate-500">Tell us a little about your business and we’ll put together a tailored quote.</p>
          <form action="https://api.web3forms.com/submit" method="POST" class="mt-6 grid gap-4 sm:grid-cols-2">
            <input type="hidden" name="access_key" value={WEB3FORMS_ACCESS_KEY} />
            <input type="hidden" name="subject" value="Website enquiry — Quote request" />
            <input type="hidden" name="from_name" value="MyFINANCE Online website" />
            <input type="hidden" name="redirect" value={REDIRECT_URL} />
            <input type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" autocomplete="off" />

            <div>
              <label class="label" for="q-name">Name</label>
              <input class="field" id="q-name" type="text" name="name" required placeholder="Your name" />
            </div>
            <div>
              <label class="label" for="q-email">Email</label>
              <input class="field" id="q-email" type="email" name="email" required placeholder="you@example.com" />
            </div>
            <div>
              <label class="label" for="q-business">Business name</label>
              <input class="field" id="q-business" type="text" name="business_name" placeholder="Your business" />
            </div>
            <div>
              <label class="label" for="q-entity">Entity type</label>
              <select class="field" id="q-entity" name="entity_type">
                <option value="">Select…</option>
                <option>Private company (Pty) Ltd</option>
                <option>Close corporation (CC)</option>
                <option>Sole proprietor</option>
                <option>Trust</option>
                <option>Non-profit (NPC)</option>
                <option>Partnership</option>
                <option>Individual</option>
              </select>
            </div>
            <div class="sm:col-span-2">
              <label class="label">Services you’re interested in</label>
              <div class="grid gap-2 sm:grid-cols-2">
                {['Accounting & bookkeeping', 'Annual financial statements', 'Tax & SARS', 'Payroll', 'CIPC / company secretarial', 'Business advisory'].map((s) => (
                  <label class="flex items-center gap-2.5 rounded-xl border border-slate-200 px-3 py-2.5 text-sm text-navy">
                    <input type="checkbox" name="services" value={s} class="h-4 w-4 rounded border-slate-300 text-accent focus:ring-accent" />
                    {s}
                  </label>
                ))}
              </div>
            </div>
            <div>
              <label class="label" for="q-turnover">Annual turnover band</label>
              <select class="field" id="q-turnover" name="turnover_band">
                <option value="">Select…</option>
                <option>Under R1 million</option>
                <option>R1m – R5m</option>
                <option>R5m – R20m</option>
                <option>R20m – R50m</option>
                <option>Over R50 million</option>
              </select>
            </div>
            <div>
              <label class="label" for="q-phone">Phone (optional)</label>
              <input class="field" id="q-phone" type="tel" name="phone" placeholder="082 000 0000" />
            </div>
            <div class="sm:col-span-2">
              <label class="label" for="q-notes">Anything else we should know?</label>
              <textarea class="field" id="q-notes" name="message" rows="3" placeholder="Optional"></textarea>
            </div>
            <div class="sm:col-span-2">
              <button type="submit" class="btn-primary w-full sm:w-auto">Request my quote</button>
            </div>
          </form>
        </div>

        <!-- Book a callback -->
        <div id="callback" class="scroll-mt-24 rounded-2xl border border-slate-200 bg-white p-7 shadow-sm">
          <h2 class="text-xl font-bold text-navy">Book a callback</h2>
          <p class="mt-1.5 text-sm text-slate-500">Leave your number and the best time, and we’ll call you.</p>
          <form action="https://api.web3forms.com/submit" method="POST" class="mt-6 grid gap-4 sm:grid-cols-2">
            <input type="hidden" name="access_key" value={WEB3FORMS_ACCESS_KEY} />
            <input type="hidden" name="subject" value="Website enquiry — Callback request" />
            <input type="hidden" name="from_name" value="MyFINANCE Online website" />
            <input type="hidden" name="redirect" value={REDIRECT_URL} />
            <input type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" autocomplete="off" />

            <div>
              <label class="label" for="c-name">Name</label>
              <input class="field" id="c-name" type="text" name="name" required placeholder="Your name" />
            </div>
            <div>
              <label class="label" for="c-phone">Phone</label>
              <input class="field" id="c-phone" type="tel" name="phone" required placeholder="082 000 0000" />
            </div>
            <div class="sm:col-span-2">
              <label class="label" for="c-time">Best time to call</label>
              <select class="field" id="c-time" name="best_time">
                <option value="">Select…</option>
                <option>Morning (08:00–12:00)</option>
                <option>Afternoon (12:00–17:00)</option>
                <option>Any time during business hours</option>
              </select>
            </div>
            <div class="sm:col-span-2">
              <button type="submit" class="btn-primary w-full sm:w-auto">Request a callback</button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </section>
</Base>
