---
import Base from '../layouts/Base.astro';
import CtaBand from '../components/CtaBand.astro';

const services = [
  {
    title: 'Accounting & bookkeeping',
    body: 'Cloud-based monthly processing, bank reconciliations and management accounts so you always know where the business stands.',
  },
  {
    title: 'Annual financial statements',
    body: 'Compliant annual financial statements compiled to ISRS 4410, ready for the bank, SARS and your shareholders.',
  },
  {
    title: 'Tax & SARS compliance',
    body: 'Income tax, provisional tax, VAT and PAYE — registered, calculated, submitted and followed up with SARS on your behalf.',
  },
  {
    title: 'Payroll',
    body: 'Monthly payslips, EMP201 submissions, EMP501 reconciliations, IRP5s and UIF — accurate and on time, every month.',
  },
  {
    title: 'Company secretarial (CIPC)',
    body: 'Company registrations, annual returns, director and address changes, beneficial-ownership filings and share certificates.',
  },
  {
    title: 'Business advisory',
    body: 'Budgets, cash-flow planning, tax structuring and a sounding board for the decisions that move your business forward.',
  },
];

const reasons = [
  {
    title: 'A registered professional',
    body: 'A SAIPA Professional Accountant (SA) and Commissioner of Oaths — your work is in qualified, accountable hands.',
  },
  {
    title: 'Cloud-first, paper-light',
    body: 'Modern cloud accounting and a secure client portal mean less admin, faster answers and no shoebox of receipts.',
  },
  {
    title: 'Proactive, not reactive',
    body: 'We watch your deadlines and reach out before they bite — you won’t be the one chasing us in February.',
  },
  {
    title: 'One firm for everything',
    body: 'Books, tax, payroll and CIPC under one roof, so nothing falls between the cracks of separate providers.',
  },
];
---
<Base>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-navy-deep">
    <div class="pointer-events-none absolute inset-0 opacity-[0.06]"
         style="background-image:linear-gradient(#fff 1px,transparent 1px),linear-gradient(90deg,#fff 1px,transparent 1px);background-size:56px 56px"></div>
    <div class="pointer-events-none absolute -left-32 -top-32 h-[28rem] w-[28rem] rounded-full bg-accent/10 blur-3xl"></div>

    <div class="container-v relative grid items-center gap-12 py-24 lg:grid-cols-[1.1fr_0.9fr] lg:py-28">
      <div>
        <span class="eyebrow">Cloud accounting · Bloemfontein, South Africa</span>
        <h1 class="mt-5 text-5xl font-bold leading-[1.08] tracking-tight text-white sm:text-6xl">
          Your numbers,<br /><span class="text-accent">handled.</span>
        </h1>
        <p class="mt-6 max-w-xl text-lg leading-relaxed text-white/60">
          MyFINANCE Online is a professional accounting practice for South African business owners — accounting, tax, payroll and CIPC compliance in one place, with a registered professional behind every figure.
        </p>
        <div class="mt-9 flex flex-wrap items-center gap-3">
          <a href="/contact#quote" class="btn-primary">Request a quote</a>
          <a href="/services" class="btn-ghost">See our services</a>
        </div>
        <p class="mt-5 text-sm text-white/40">SAIPA Professional Accountant (SA) · Commissioner of Oaths</p>
      </div>

      <!-- Faux dashboard window -->
      <div class="overflow-hidden rounded-2xl border border-white/10 bg-white shadow-2xl shadow-black/40">
        <div class="flex items-center gap-2 border-b border-slate-100 bg-slate-50 px-4 py-3">
          <span class="h-2.5 w-2.5 rounded-full bg-slate-300"></span>
          <span class="h-2.5 w-2.5 rounded-full bg-slate-300"></span>
          <span class="h-2.5 w-2.5 rounded-full bg-slate-300"></span>
          <span class="ml-2 text-xs font-medium text-slate-400">MyFINANCE Online · Your dashboard</span>
        </div>
        <div class="p-5">
          <div class="flex flex-wrap gap-2">
            <span class="rounded-full bg-accent-soft px-2.5 py-1 text-[11px] font-semibold text-accent">● Books up to date</span>
            <span class="rounded-full bg-navy/10 px-2.5 py-1 text-[11px] font-semibold text-navy">VAT due 25 Jun</span>
          </div>

          <div class="mt-4 overflow-hidden rounded-xl border border-slate-200">
            {[['VAT201 submission', 'Filed', 'green'], ['Monthly management pack', 'Ready', 'navy'], ['Provisional tax (IRP6)', 'In progress', 'amber']].map(([job, status, tone]) => (
              <div class="flex items-center justify-between gap-3 border-b border-slate-100 px-3 py-2.5 last:border-0">
                <div class="flex items-center gap-2.5">
                  <span class={`h-2 w-2 flex-shrink-0 rounded-full ${tone === 'amber' ? 'bg-accent' : tone === 'green' ? 'bg-green-500' : 'bg-navy'}`}></span>
                  <span class="text-xs font-medium text-navy">{job}</span>
                </div>
                <span class="whitespace-nowrap text-[11px] text-slate-500">{status}</span>
              </div>
            ))}
          </div>

          <div class="mt-4 grid grid-cols-3 gap-2 text-center">
            {[['On-time filings', '100%'], ['Cloud-based', 'Yes'], ['Years in practice', '10+']].map(([k, v]) => (
              <div class="rounded-xl bg-slate-50 px-2 py-3">
                <div class="text-base font-bold text-navy">{v}</div>
                <div class="mt-0.5 text-[10px] uppercase tracking-wide text-slate-400">{k}</div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services overview -->
  <section class="container-v py-24">
    <div class="max-w-2xl">
      <span class="eyebrow">What we do</span>
      <h2 class="mt-4 text-3xl font-bold tracking-tight text-navy sm:text-4xl">Everything your business needs to stay compliant — and clear.</h2>
      <p class="mt-4 text-lg leading-relaxed text-slate-600">From day-to-day bookkeeping to the annual financial statements your bank asks for, we cover the full compliance cycle so you can get on with running the business.</p>
    </div>

    <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {services.map((s) => (
        <div class="card">
          <h3 class="text-lg font-semibold text-navy">{s.title}</h3>
          <p class="mt-3 text-sm leading-relaxed text-slate-600">{s.body}</p>
        </div>
      ))}
    </div>

    <div class="mt-10">
      <a href="/services" class="btn-dark">Explore all services</a>
    </div>
  </section>

  <!-- Why us -->
  <section class="bg-slate-50 py-24">
    <div class="container-v">
      <div class="max-w-2xl">
        <span class="eyebrow">Why MyFINANCE Online</span>
        <h2 class="mt-4 text-3xl font-bold tracking-tight text-navy sm:text-4xl">A modern firm that actually picks up the phone.</h2>
      </div>
      <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-4">
        {reasons.map((r) => (
          <div class="rounded-2xl border border-slate-200 bg-white p-6">
            <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-accent-soft text-accent font-bold">✓</div>
            <h3 class="mt-4 text-base font-semibold text-navy">{r.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-slate-600">{r.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CtaBand />
</Base>
