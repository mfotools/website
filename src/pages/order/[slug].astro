---
import Base from '../../layouts/Base.astro';
import FormField from '../../components/FormField.astro';
import { SERVICES, CONTACT_FIELDS, getService } from '../../data/order';
import {
  PAYFAST,
  PAYFAST_PROCESS_URL,
  WEB3FORMS_ACCESS_KEY,
  WEB3FORMS_URL,
  RETURN_URL,
  CANCEL_URL,
} from '../../data/payment';

export function getStaticPaths() {
  return SERVICES.filter((s) => !s.hidden).map((s) => ({ params: { slug: s.slug } }));
}

const { slug } = Astro.params;
const service = getService(slug!)!;
const zar = (n: number) => 'R' + n.toLocaleString('en-ZA');
const amount = service.price.toFixed(2); // PayFast wants "1250.00"
const fields = [...CONTACT_FIELDS, ...service.fields];
---
<Base
  title={`${service.title} — Order online — MyFINANCE Online`}
  description={service.summary}
>
  <!-- Header -->
  <section class="bg-navy-deep">
    <div class="container-v py-16">
      <a href="/order" class="text-sm font-medium text-white/60 hover:text-white">← All services</a>
      <span class="mt-6 block eyebrow">{service.category}</span>
      <h1 class="mt-3 max-w-3xl text-3xl font-bold leading-tight tracking-tight text-white sm:text-4xl">
        {service.title}
      </h1>
      <p class="mt-4 max-w-2xl text-lg leading-relaxed text-white/60">{service.summary}</p>
      <div class="mt-6 flex flex-wrap items-center gap-4">
        <span class="rounded-xl bg-white/10 px-4 py-2 text-lg font-bold text-white">{zar(service.price)} <span class="text-sm font-normal text-white/60">incl. VAT</span></span>
        {service.turnaround && <span class="text-sm text-white/50">Typical turnaround: {service.turnaround}</span>}
      </div>
      {service.priceNote && <p class="mt-3 max-w-2xl text-sm leading-relaxed text-white/60">* {service.priceNote}</p>}
    </div>
  </section>

  <section class="container-v py-16">
    <div class="mx-auto max-w-2xl rounded-2xl border border-slate-200 bg-white p-7 shadow-sm">
      {service.info && (
        <details class="group mb-6 rounded-xl border border-slate-200 bg-slate-50/60 px-4 py-3">
          <summary class="flex cursor-pointer items-center justify-between text-sm font-semibold text-navy marker:content-['']">
            <span>More about this service</span>
            <span class="text-accent transition-transform group-open:rotate-180">▾</span>
          </summary>
          <p class="mt-3 text-sm leading-relaxed text-slate-600">{service.info}</p>
        </details>
      )}

      <!-- Order form → posts to Web3Forms (records the order by email) -->
      <form id="orderForm" action={WEB3FORMS_URL} method="POST" class="grid gap-4 sm:grid-cols-2">
        <input type="hidden" name="access_key" value={WEB3FORMS_ACCESS_KEY} />
        <input type="hidden" name="subject" value={`Service order — ${service.title}`} />
        <input type="hidden" name="from_name" value="MyFINANCE Online website" />
        <input type="hidden" name="service" value={service.title} />
        <input type="hidden" name="price" value={`R${service.price}`} />
        <input type="hidden" name="redirect" value={RETURN_URL} />
        <!-- honeypot -->
        <input type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" autocomplete="off" />

        {fields.map((f) => <FormField field={f} />)}

        <div class="sm:col-span-2 mt-2 flex flex-col gap-3 sm:flex-row-reverse sm:items-center">
          <button type="button" id="payNowBtn" class="btn-primary w-full sm:w-auto">
            Pay now — {zar(service.price)}
          </button>
          <button type="submit" class="btn-dark w-full sm:w-auto">
            Request service (pay later)
          </button>
        </div>
        <p id="payError" class="sm:col-span-2 hidden text-sm text-red-600"></p>
        <p class="sm:col-span-2 text-xs text-slate-400">
          Secure payment handled by PayFast. Choosing “Pay later” sends us your request and we’ll invoice you.
        </p>
      </form>

      <!-- Hidden PayFast form — populated + submitted by JS after the order is recorded -->
      <form id="payfastForm" action={PAYFAST_PROCESS_URL} method="POST" class="hidden">
        <input type="hidden" name="merchant_id" value={PAYFAST.merchantId} />
        <input type="hidden" name="merchant_key" value={PAYFAST.merchantKey} />
        <input type="hidden" name="return_url" value={RETURN_URL} />
        <input type="hidden" name="cancel_url" value={CANCEL_URL} />
        <input type="hidden" name="amount" value={amount} />
        <input type="hidden" name="item_name" value={service.title} />
        <input type="hidden" name="item_description" value={service.summary} />
        <input type="hidden" name="custom_str1" value={service.slug} />
        <input type="hidden" name="name_first" id="pf_name" value="" />
        <input type="hidden" name="email_address" id="pf_email" value="" />
        <input type="hidden" name="m_payment_id" id="pf_ref" value="" />
      </form>
    </div>
  </section>

  <script is:inline define:vars={{ WEB3FORMS_URL, slug }}>
    const orderForm = document.getElementById('orderForm');
    const payfastForm = document.getElementById('payfastForm');
    const payBtn = document.getElementById('payNowBtn');
    const errEl = document.getElementById('payError');

    // Repeater blocks (e.g. directors): show N blocks per the "how many?" count,
    // and disable inputs in hidden blocks so they neither validate nor submit.
    document.querySelectorAll('[data-repeater]').forEach((rep) => {
      const countSel = rep.querySelector('[data-repeater-count]');
      const items = rep.querySelectorAll('[data-repeater-item]');
      const apply = () => {
        const n = parseInt(countSel.value || '0', 10);
        items.forEach((item, idx) => {
          const show = idx < n;
          item.style.display = show ? '' : 'none';
          item.querySelectorAll('input, select, textarea').forEach((inp) => {
            inp.disabled = !show;
          });
        });
      };
      countSel.addEventListener('change', apply);
      apply();
    });

    // Conditional fields: show only when a controlling field's value matches.
    // Works for select and radio-group controls. `data-show-when-values`
    // (pipe-separated) means "match any of these"; otherwise use the single
    // `data-show-when-equals`. Hidden fields are disabled so they don't submit.
    document.querySelectorAll('[data-show-when-field]').forEach((el) => {
      const ctrlName = el.getAttribute('data-show-when-field');
      const equals = el.getAttribute('data-show-when-equals');
      const values = el.getAttribute('data-show-when-values');
      const allowed = values ? values.split('|') : equals != null ? [equals] : [];
      const controls = orderForm.querySelectorAll('[name="' + ctrlName + '"]');
      if (!controls.length) return;

      const currentValue = () => {
        for (const c of controls) {
          if (c.type === 'radio' || c.type === 'checkbox') {
            if (c.checked) return c.value;
          } else {
            return c.value;
          }
        }
        return '';
      };
      const apply = () => {
        const show = allowed.includes(currentValue());
        el.style.display = show ? '' : 'none';
        el.querySelectorAll('input, select, textarea').forEach((inp) => {
          inp.disabled = !show;
        });
      };
      controls.forEach((c) => c.addEventListener('change', apply));
      apply();
    });

    function showError(msg) {
      errEl.textContent = msg;
      errEl.classList.remove('hidden');
    }

    payBtn.addEventListener('click', async () => {
      // Use the browser's native validation on the visible order form.
      if (!orderForm.reportValidity()) return;

      errEl.classList.add('hidden');
      payBtn.disabled = true;
      const original = payBtn.textContent;
      payBtn.textContent = 'Processing…';

      // 1) Record the order with Web3Forms (so we get the email even if the
      //    customer bails out of the PayFast checkout).
      try {
        const data = Object.fromEntries(new FormData(orderForm).entries());
        const res = await fetch(WEB3FORMS_URL, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
          body: JSON.stringify(data),
        });
        const json = await res.json();
        if (!json.success) throw new Error(json.message || 'Submission failed');
      } catch (e) {
        payBtn.disabled = false;
        payBtn.textContent = original;
        showError('Sorry — we couldn’t record your request. Please try again, or use “Pay later”.');
        return;
      }

      // 2) Hand off to PayFast for the fixed amount.
      const fd = new FormData(orderForm);
      document.getElementById('pf_name').value = (fd.get('name') || '').toString().split(' ')[0];
      document.getElementById('pf_email').value = (fd.get('email') || '').toString();
      document.getElementById('pf_ref').value = slug + '-' + Date.now();
      payfastForm.submit();
    });
  </script>
</Base>
