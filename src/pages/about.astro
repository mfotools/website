---
import Base from '../layouts/Base.astro';
import CtaBand from '../components/CtaBand.astro';

const values = [
  {
    title: 'Accountable',
    body: 'A registered SAIPA Professional Accountant (SA) stands behind every set of figures and every submission.',
  },
  {
    title: 'Accessible',
    body: 'Real answers from a real person — not a call-centre ticket. We know your business by name.',
  },
  {
    title: 'Ahead of the deadline',
    body: 'We track the SARS and CIPC calendar for you and act early, so compliance is calm rather than a crisis.',
  },
];

// Team. No photos supplied — monogram avatars are generated from the initials
// in brand colours. To use real photos later, add a `photo: '/team/name.jpg'`
// field and render an <img> instead of the initials block.
const team = [
  {
    name: 'Jannie Schutte',
    role: 'Managing Director · Professional Accountant (SA)',
    bio: 'An expert in business and accounting technology, with experience across JSE-listed entities and start-ups. A dedicated family man and neighbourhood braai specialist.',
    email: 'jschutte@myfinance-online.co.za',
    tone: 'navy',
  },
  {
    name: 'Graham Maguire',
    role: 'Senior Cloud Accountant · Professional Accountant (SA)',
    bio: 'A SAIPA-registered Professional Accountant (SA) with several years’ experience and a keen outdoor enthusiast.',
    email: 'graham@myfinance-online.co.za',
    tone: 'accent',
  },
  {
    name: 'Carolie Marx',
    role: 'Senior Cloud Accountant · Professional Accountant (SA)',
    bio: 'A SAIPA-registered Professional Accountant (SA) with over a decade of experience, combining deep expertise with a calm, considered approach to every engagement.',
    email: 'carolie@myfinance-online.co.za',
    tone: 'sky',
  },
  {
    name: 'Elrina Hofmyer',
    role: 'Senior Cloud Accountant',
    bio: 'An experienced accountant with a keen eye for detail — and a proud mother of two.',
    email: 'elrina@myfinance-online.co.za',
    tone: 'navy',
  },
  {
    name: 'Ednese van der Merwe',
    role: 'Client Liaison & Executive Assistant',
    bio: 'Specialises in CIPC, COIDA and payroll, bringing youthful energy and a commitment to excellence to every client interaction.',
    email: 'ednese@myfinance-online.co.za',
    tone: 'accent',
  },
];

const initials = (name) => name.split(' ').filter(Boolean).map((p) => p[0]).slice(0, 2).join('').toUpperCase();
const toneClass = { navy: 'bg-navy', accent: 'bg-accent', sky: 'bg-sky' };
---
<Base title="About — MyFINANCE Online" description="MyFINANCE Online is a Bloemfontein-based professional accounting practice led by a SAIPA Professional Accountant (SA) and Commissioner of Oaths.">
  <!-- Header -->
  <section class="bg-navy-deep">
    <div class="container-v grid items-center gap-12 py-20 lg:grid-cols-[1.1fr_0.9fr]">
      <div>
        <span class="eyebrow">About the firm</span>
        <h1 class="mt-4 text-4xl font-bold leading-tight tracking-tight text-white sm:text-5xl">
          A professional practice that treats your business like its own.
        </h1>
        <p class="mt-5 max-w-xl text-lg leading-relaxed text-white/60">
          Since 2008, MyFINANCE Online has empowered South African business owners in a reliable, professional manner. We’re a Bloemfontein-based practice that combines the rigour of a registered professional firm with the convenience of cloud accounting and a secure client portal.
        </p>
      </div>
      <div class="rounded-2xl border border-white/10 bg-white/5 p-7">
        <h2 class="text-sm font-semibold uppercase tracking-wider text-white/40">Credentials</h2>
        <ul class="mt-4 space-y-3 text-sm text-white/75">
          <li class="flex items-start gap-2.5"><span class="mt-0.5 text-accent">●</span> SAIPA Professional Accountant (SA)</li>
          <li class="flex items-start gap-2.5"><span class="mt-0.5 text-accent">●</span> Commissioner of Oaths</li>
          <li class="flex items-start gap-2.5"><span class="mt-0.5 text-accent">●</span> Registered SARS tax practitioner</li>
          <li class="flex items-start gap-2.5"><span class="mt-0.5 text-accent">●</span> Based in Bloemfontein, Free State</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Story -->
  <section class="container-v py-24">
    <div class="grid gap-12 lg:grid-cols-[1fr_1fr]">
      <div>
        <span class="eyebrow">Our approach</span>
        <h2 class="mt-4 text-3xl font-bold tracking-tight text-navy">Compliance handled, so you can focus on the business.</h2>
      </div>
      <div class="space-y-5 text-base leading-relaxed text-slate-600">
        <p>
          Most business owners don’t want to think about accounting — they want it done, done right, and done on time. That’s the brief we work to. We take care of the books, the tax and the statutory filings in the background, and surface only the numbers and decisions that matter to you.
        </p>
        <p>
          Working in the cloud means you’re never tied to a desktop or a filing cabinet. Share documents securely, approve work online and see exactly where things stand — from anywhere, on any device.
        </p>
        <p>
          And because we’re a registered professional practice, you get more than data capture: you get judgement, accountability and someone who will represent you to SARS when it counts.
        </p>
      </div>
    </div>

    <div class="mt-16 grid gap-6 md:grid-cols-3">
      {values.map((v) => (
        <div class="card">
          <h3 class="text-lg font-semibold text-navy">{v.title}</h3>
          <p class="mt-3 text-sm leading-relaxed text-slate-600">{v.body}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Team -->
  <section class="bg-slate-50 py-24">
    <div class="container-v">
      <div class="max-w-2xl">
        <span class="eyebrow">Our team</span>
        <h2 class="mt-4 text-3xl font-bold tracking-tight text-navy sm:text-4xl">Dedicated experts behind your numbers.</h2>
        <p class="mt-4 text-lg leading-relaxed text-slate-600">A close-knit team of cloud accountants and client specialists — empowering your business in a reliable, professional manner since 2008.</p>
      </div>

      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {team.map((m) => (
          <div class="flex flex-col rounded-2xl border border-slate-200 bg-white p-7">
            <div class="flex items-center gap-4">
              <div class={`flex h-14 w-14 flex-shrink-0 items-center justify-center rounded-full text-lg font-bold text-white ${toneClass[m.tone]}`}>
                {initials(m.name)}
              </div>
              <div>
                <h3 class="text-base font-semibold text-navy">{m.name}</h3>
                <p class="text-sm text-accent">{m.role}</p>
              </div>
            </div>
            <p class="mt-4 flex-1 text-sm leading-relaxed text-slate-600">{m.bio}</p>
            <a href={`mailto:${m.email}`} class="mt-4 inline-flex items-center gap-1.5 text-sm font-medium text-sky hover:underline">
              {m.email}
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CtaBand heading="Work with a firm that knows you by name." sub="Get in touch and let’s talk about what your business needs." />
</Base>
