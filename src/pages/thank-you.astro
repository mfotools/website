---
import Base from '../layouts/Base.astro';
---
<Base title="Thank you — MyFINANCE Online" description="Thanks for getting in touch with MyFINANCE Online.">
  <section class="bg-navy-deep">
    <div class="container-v flex min-h-[60vh] flex-col items-center justify-center py-24 text-center">
      <div class="flex h-16 w-16 items-center justify-center rounded-2xl bg-accent text-3xl text-white">✓</div>
      <h1 class="mt-6 text-4xl font-bold tracking-tight text-white">Thank you — we’ve got it.</h1>
      <p class="mt-4 max-w-md text-lg leading-relaxed text-white/60">
        Your message has been sent. We’ll be in touch within one business day. In the meantime, feel free to look around.
      </p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
        <a href="/" class="btn-primary">Back to home</a>
        <a href="/services" class="btn-ghost">View our services</a>
      </div>
    </div>
  </section>
</Base>
