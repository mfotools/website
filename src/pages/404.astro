---
import Base from '../layouts/Base.astro';
---
<Base title="Page not found — MyFINANCE Online">
  <section class="bg-navy-deep">
    <div class="container-v flex min-h-[60vh] flex-col items-center justify-center py-24 text-center">
      <span class="eyebrow">404</span>
      <h1 class="mt-4 text-4xl font-bold tracking-tight text-white">We couldn’t find that page.</h1>
      <p class="mt-4 max-w-md text-lg leading-relaxed text-white/60">
        The page you’re looking for may have moved or no longer exists.
      </p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
        <a href="/" class="btn-primary">Back to home</a>
        <a href="/contact" class="btn-ghost">Contact us</a>
      </div>
    </div>
  </section>
</Base>
